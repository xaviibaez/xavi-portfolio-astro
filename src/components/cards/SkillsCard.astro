---
import type { Translations } from '@/i18n/en';

interface Props {
  translation: Translations;
  fullWidth?: boolean;
}

const { translation, fullWidth = false } = Astro.props;

const skillGroups = [
  {
    label: translation.skills.backend,
    skills: ['Java', 'Kotlin', 'Spring Boot', 'Spring Batch', 'Python', 'Django', 'C#', '.NET', 'PHP', 'Laravel', 'Node.js', 'Express.js'],
  },
  {
    label: translation.skills.frontend,
    skills: ['TypeScript', 'JavaScript', 'HTML5', 'CSS3', 'Angular', 'React', 'Vue.js', 'Nuxt', 'Astro', 'Tailwind CSS'],
  },
  {
    label: translation.skills.databases,
    skills: ['Oracle', 'MySQL', 'SQL Server', 'PL/SQL', 'MongoDB', 'Elasticsearch', 'Redis'],
  },
  {
    label: translation.skills.infra,
    skills: ['AWS', 'Docker', 'Kafka', 'Jenkins'],
  },
  {
    label: translation.skills.testing,
    skills: ['JUnit', 'Mockito', 'Jest'],
  },
  {
    label: translation.skills.practices,
    skills: ['Microservices', 'DDD', 'CQRS', 'TDD', 'ATDD', 'ED', 'CI/CD', 'Hexagonal', 'Reactive'],
  },
];
---

<div class:list={["bento-card flex flex-col gap-4", fullWidth ? "bento-col-4" : "bento-col-2"]}>
  <p class="text-muted text-[0.75rem] font-semibold uppercase tracking-widest">{translation.skills.title}</p>
  <div class="flex flex-col divide-y divide-border">
    {skillGroups.map((group) => (
      <div class="grid grid-cols-[110px_1fr] gap-4 py-2.5 first:pt-0 last:pb-0">
        <span class="text-muted text-[0.72rem] font-semibold uppercase tracking-wider pt-0.5">{group.label}</span>
        <span class="text-fg text-[0.88rem] leading-relaxed">{group.skills.join(' · ')}</span>
      </div>
    ))}
  </div>
</div>
