---
import type { Translations } from '@/i18n/en';

interface Props {
  translation: Translations;
}

const { translation } = Astro.props;

const skills = [
  { name: 'Java', level: 5 },
  { name: 'Spring Boot', level: 5 },
  { name: 'TypeScript', level: 4 },
  { name: 'Node.js', level: 4 },
  { name: 'C#', level: 4 },
  { name: '.NET', level: 3 },
  { name: 'Angular', level: 3 },
  { name: 'React', level: 3 },
  { name: 'Vue.js', level: 3 },
  { name: 'Docker', level: 4 },
  { name: 'Kubernetes', level: 3 },
  { name: 'AWS', level: 3 },
  { name: 'Redis', level: 4 },
  { name: 'PostgreSQL', level: 4 },
  { name: 'Oracle', level: 3 },
  { name: 'Elasticsearch', level: 3 },
];
---

<div class="bento-card bento-col-2 flex flex-col gap-4">
  <p class="text-muted text-[0.75rem] font-semibold uppercase tracking-widest">{translation.skills.title}</p>
  <div class="flex flex-wrap gap-2">
    {skills.map((skill) => (
      <span class="tag">{skill.name}</span>
    ))}
  </div>
</div>
