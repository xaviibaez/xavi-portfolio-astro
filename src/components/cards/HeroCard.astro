---
import type { Translations } from '@/i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<div class="bento-card hero-card">
  <div class="hero-content">
    <div class="hero-avatar">
      <span class="avatar-initials">XI</span>
    </div>
    <div class="hero-text">
      <p class="hero-greeting text-muted">{t.hero.greeting}</p>
      <h1 class="hero-name">{t.hero.name}</h1>
      <p class="hero-role">
        <span class="accent">{t.hero.role}</span>
        <span class="text-muted"> · {t.hero.company}</span>
      </p>
      <p class="hero-bio text-muted">{t.hero.bio}</p>
      <div class="hero-actions">
        <a href="#projects" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          {t.hero.cta}
        </a>
        <a href="#blog" class="btn-ghost">{t.hero.ctaBlog}</a>
      </div>
    </div>
  </div>

  <div class="hero-decoration">
    <div class="deco-circle deco-1"></div>
    <div class="deco-circle deco-2"></div>
  </div>
</div>

<style>
  .hero-card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .hero-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent-hover));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .avatar-initials {
    color: white;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hero-greeting {
    font-size: 0.9rem;
    font-weight: 500;
  }

  .hero-name {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--fg);
  }

  .hero-role {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .hero-bio {
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 380px;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .hero-decoration {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    border-radius: inherit;
  }

  .deco-circle {
    position: absolute;
    border-radius: 50%;
    background: var(--accent-muted);
    opacity: 0.5;
  }

  .deco-1 {
    width: 200px;
    height: 200px;
    bottom: -80px;
    right: -80px;
  }

  .deco-2 {
    width: 120px;
    height: 120px;
    top: -40px;
    right: 40px;
    opacity: 0.3;
  }

  @media (min-width: 900px) {
    .hero-card {
      grid-column: span 2;
      grid-row: span 2;
    }
  }
</style>
