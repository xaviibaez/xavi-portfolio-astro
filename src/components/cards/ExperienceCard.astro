---
import type { Translations } from '@/i18n/en';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<div class="bento-card experience-card">
  <p class="card-label text-muted">{t.experience.title}</p>
  <div class="timeline">
    {t.experience.jobs.map((job, i) => (
      <div class="timeline-item">
        <div class="timeline-dot" class:list={[i === 0 && 'active']}></div>
        {i < t.experience.jobs.length - 1 && <div class="timeline-line"></div>}
        <div class="timeline-content">
          <div class="job-header">
            <span class="job-role">{job.role}</span>
            {i === 0 && <span class="job-current">{t.experience.current}</span>}
          </div>
          <span class="job-company text-muted">{job.company}</span>
          <span class="job-period text-muted">{job.period}</span>
          <p class="job-desc text-muted">{job.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  @media (min-width: 900px) {
    .experience-card {
      grid-column: span 2;
      grid-row: span 2;
    }
  }

  .experience-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 20px 1fr;
    grid-template-rows: auto 1fr;
    column-gap: 0.75rem;
  }

  .timeline-dot {
    grid-column: 1;
    grid-row: 1;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--border);
    border: 2px solid var(--bg-card);
    outline: 2px solid var(--border);
    margin-top: 3px;
    justify-self: center;
  }

  .timeline-dot.active {
    background-color: var(--accent);
    outline-color: var(--accent-muted);
  }

  .timeline-line {
    grid-column: 1;
    grid-row: 2;
    width: 2px;
    background-color: var(--border);
    justify-self: center;
    min-height: 1rem;
    margin: 4px 0;
  }

  .timeline-content {
    grid-column: 2;
    grid-row: 1 / -1;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-bottom: 1.25rem;
  }

  .job-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .job-role {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--fg);
  }

  .job-current {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    border-radius: 9999px;
    background-color: var(--accent-muted);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .job-company {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .job-period {
    font-size: 0.75rem;
    font-family: monospace;
  }

  .job-desc {
    font-size: 0.82rem;
    line-height: 1.5;
    margin-top: 0.25rem;
  }

</style>
