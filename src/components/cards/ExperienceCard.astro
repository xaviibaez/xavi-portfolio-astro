---
import type { Translations } from '@/i18n/en';

interface Props {
  translation: Translations;
}

const { translation } = Astro.props;
---

<div class="bento-card bento-col-2-row-2 flex flex-col gap-4">
  <p class="text-muted text-[0.75rem] font-semibold uppercase tracking-widest">{translation.experience.title}</p>
  <div class="flex flex-col flex-1">
    {translation.experience.jobs.map((job, i) => (
      <div class="grid grid-cols-[20px_1fr] grid-rows-[auto_1fr] gap-x-3">
        <div
          class:list={[
            'w-3 h-3 rounded-full border-2 border-bg-card outline outline-2 mt-[3px] justify-self-center col-[1] row-[1]',
            i === 0 ? 'bg-accent outline-accent-muted' : 'bg-border outline-border',
          ]}
        ></div>
        {i < translation.experience.jobs.length - 1 && (
          <div class="col-[1] row-[2] w-0.5 bg-border justify-self-center min-h-4 my-1"></div>
        )}
        <div class="col-[2] row-[1/-1] flex flex-col gap-0.5 pb-5">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="font-semibold text-[0.9rem] text-fg">{job.role}</span>
            {i === 0 && (
              <span class="text-[0.65rem] font-semibold px-1.5 py-0.5 rounded-full uppercase tracking-wide bg-accent-muted text-accent">
                {translation.experience.current}
              </span>
            )}
          </div>
          <span class="text-muted text-[0.85rem] font-medium">{job.company}</span>
          <span class="text-muted text-[0.75rem] font-mono">{job.period}</span>
          <p class="text-muted text-[0.82rem] leading-relaxed mt-1">{job.description}</p>
        </div>
      </div>
    ))}
  </div>
</div>
