---
import NavReact from './NavIsland';
import type { Lang } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = lang === 'es' ? '/es' : '';

const currentPath = Astro.url.pathname;
let targetPath = '/';
if (lang === 'en') {
  targetPath = currentPath === '/' ? '/es' : `/es${currentPath}`;
} else {
  targetPath = currentPath.replace(/^\/es/, '') || '/';
}
---

<script is:inline>
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-theme-key]');
    if (!btn) return;
    var theme = btn.getAttribute('data-theme-key');
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('xavi-theme', theme);
    var details = btn.closest('details');
    if (details) details.open = false;
  });
</script>

<NavReact
  client:load
  lang={lang}
  base={base}
  t={{
    nav: { home: t.nav.home, blog: t.nav.blog, projects: t.nav.projects },
    language: { toggle: t.language.toggle, en: t.language.en, es: t.language.es },
    theme: { toggle: t.theme.toggle, light: t.theme.light, dark: t.theme.dark, blue: t.theme.blue, green: t.theme.green },
  }}
  targetPath={targetPath}
/>
