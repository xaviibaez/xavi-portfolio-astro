---
import NavReact from './NavIsland';
import type { Lang } from '@/i18n/utils';
import { useTranslations, getLangBase, getNextLang, getPathForLang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const translation = useTranslations(lang);
const base = getLangBase(lang);
const currentPath = Astro.url.pathname;

const nextLang = getNextLang(lang);
const targetPath = getPathForLang(currentPath, lang, nextLang);
---

<NavReact
  client:load
  lang={lang}
  base={base}
  nextLangName={translation.language[nextLang]}
  targetPath={targetPath}
  translation={{
    language: { toggle: translation.language.toggle },
    theme: { toggle: translation.theme.toggle },
  }}
/>
