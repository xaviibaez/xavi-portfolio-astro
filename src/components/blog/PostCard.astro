---
import { format } from 'date-fns';
import type { Lang } from '@/i18n/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  lang: Lang;
  readMore: string;
}

const { title, description, pubDate, tags, slug, lang, readMore } = Astro.props;
const base = lang === 'es' ? '/es' : '';
const postSlug = slug.split('/').pop();
---

<article class="post-card">
  <div class="post-header">
    <time class="post-date text-muted" datetime={pubDate.toISOString()}>
      {format(pubDate, 'MMMM d, yyyy')}
    </time>
    <div class="post-tags">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
  <h2 class="post-title">
    <a href={`${base}/blog/${postSlug}`}>{title}</a>
  </h2>
  <p class="post-desc text-muted">{description}</p>
  <a href={`${base}/blog/${postSlug}`} class="read-more accent">
    {readMore} →
  </a>
</article>

<style>
  .post-card {
    padding: 1.5rem;
    border-radius: 1rem;
    border: 1px solid var(--border);
    background-color: var(--bg-card);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .post-card:hover {
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-1px);
  }

  .post-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .post-date {
    font-size: 0.8rem;
    font-family: monospace;
  }

  .post-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--fg);
  }

  .post-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .post-title a:hover {
    color: var(--accent);
  }

  .post-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    flex: 1;
  }

  .read-more {
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .read-more:hover {
    opacity: 0.8;
  }
</style>
