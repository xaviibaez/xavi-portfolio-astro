---
import { format } from 'date-fns';
import type { Lang } from '@/i18n/languageUtils';
import { getLangBase } from '@/i18n/languageUtils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  lang: Lang;
  readMore: string;
}

const { title, description, pubDate, tags, slug, lang, readMore } = Astro.props;
const base = getLangBase(lang);
const postSlug = slug.split('/').pop();
---

<article class="p-6 rounded-2xl border border-border bg-bg-card flex flex-col gap-3 transition-[box-shadow,transform] duration-150 hover:shadow-[0_4px_16px_var(--shadow)] hover:-translate-y-px">
  <div class="flex items-center justify-between flex-wrap gap-2">
    <time class="text-muted text-[0.8rem] font-mono" datetime={pubDate.toISOString()}>
      {format(pubDate, 'MMMM d, yyyy')}
    </time>
    <div class="flex gap-[0.35rem] flex-wrap">
      {tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
  <h2 class="text-[1.1rem] font-bold leading-[1.3] text-fg">
    <a href={`${base}/blog/${postSlug}`} class="text-inherit no-underline transition-colors duration-150 hover:text-accent">{title}</a>
  </h2>
  <p class="text-muted text-[0.875rem] leading-relaxed flex-1">{description}</p>
  <a href={`${base}/blog/${postSlug}`} class="accent text-[0.85rem] font-medium no-underline transition-opacity duration-150 hover:opacity-80">
    {readMore} →
  </a>
</article>
