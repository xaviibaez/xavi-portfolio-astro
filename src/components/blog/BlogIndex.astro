---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';
import { useTranslations } from '@/i18n/languageUtils';
import type { Lang } from '@/i18n/languageUtils';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const translation = useTranslations(lang);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => p.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout lang={lang} title={`Blog — Xavi Ibáñez`}>
  <div class="max-w-[800px] mx-auto px-6 py-12">
    <div class="mb-10">
      <h1 class="text-[2rem] font-extrabold tracking-[-0.03em] mb-2 text-fg">{translation.blog.allPosts}</h1>
      <p class="text-muted text-base leading-relaxed">{translation.blog.subtitle}</p>
    </div>

    {posts.length === 0 ? (
      <p class="text-muted">{translation.blog.noPosts}</p>
    ) : (
      <div class="flex flex-col gap-4">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
            lang={lang}
            readMore={translation.blog.readMore}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
