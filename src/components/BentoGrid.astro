---
import type { Translations } from '@/i18n/en';
import type { Lang } from '@/i18n/utils';
import HeroCard from './cards/HeroCard.astro';
import AboutCard from './cards/AboutCard.astro';
import SkillsCard from './cards/SkillsCard.astro';
import ExperienceCard from './cards/ExperienceCard.astro';
import ProjectsCard from './cards/ProjectsCard.astro';
import BlogCard from './cards/BlogCard.astro';
import ContactCard from './cards/ContactCard.astro';

interface Props {
  translation: Translations;
  lang: Lang;
}

const { translation, lang } = Astro.props;
---

<div class="max-w-[1200px] mx-auto px-5 py-10 sm:px-10 sm:py-14">
  <div class="bento-grid-4col grid auto-rows-[minmax(180px,auto)] gap-5 sm:gap-6">
    <!-- Row 1-2: Hero (2x2) + Experience (2x2) -->
    <HeroCard translation={translation} />
    <ExperienceCard translation={translation} />

    <!-- Row 3: About (2x1) + Skills (2x1) -->
    <AboutCard translation={translation} />
    <SkillsCard translation={translation} />

    <!-- Row 4-5: Projects (2x2) + Blog (2x1) + Contact (2x1) -->
    <ProjectsCard translation={translation} lang={lang} />
    <BlogCard translation={translation} lang={lang} />
    <ContactCard translation={translation} />
  </div>
</div>
