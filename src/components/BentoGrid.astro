---
import type { Translations } from '@/i18n/en';
import type { Lang } from '@/i18n/utils';
import HeroCard from './cards/HeroCard.astro';
import AboutCard from './cards/AboutCard.astro';
import SkillsCard from './cards/SkillsCard.astro';
import ExperienceCard from './cards/ExperienceCard.astro';
import ProjectsCard from './cards/ProjectsCard.astro';
import BlogCard from './cards/BlogCard.astro';
import ContactCard from './cards/ContactCard.astro';

interface Props {
  t: Translations;
  lang: Lang;
}

const { t, lang } = Astro.props;
---

<div class="bento-container">
  <div class="bento-grid">
    <!-- Row 1-2: Hero (2x2) + Experience (2x2) -->
    <HeroCard t={t} />
    <ExperienceCard t={t} />

    <!-- Row 3: About (2x1) + Skills (2x1) -->
    <AboutCard t={t} />
    <SkillsCard t={t} />

    <!-- Row 4-5: Projects (2x2) + Blog (2x1) + Contact (2x1) -->
    <ProjectsCard t={t} lang={lang} />
    <BlogCard t={t} lang={lang} />
    <ContactCard t={t} />
  </div>
</div>

<style>
  .bento-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1rem 3rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: minmax(160px, auto);
    gap: 1rem;
  }

  @media (min-width: 560px) {
    .bento-container {
      padding: 2rem 1.5rem 4rem;
    }

    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
