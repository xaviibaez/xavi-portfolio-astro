---
// Redirect to the default locale (en) home page.
// Astro i18n with prefixDefaultLocale: false means / is English.
import BaseLayout from '@/layouts/BaseLayout.astro';
import BentoGrid from '@/components/BentoGrid.astro';
import { useTranslations } from '@/i18n/languageUtils';

const lang = 'en';
const translation = useTranslations(lang);
---

<BaseLayout lang={lang} title="Xavi Ibáñez — Senior Backend Engineer">
  <BentoGrid translation={translation} lang={lang} />
</BaseLayout>
