---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';
import { useTranslations } from '@/i18n/utils';
import { getCollection } from 'astro:content';

const lang = 'en';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => p.id.startsWith('en/'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout lang={lang} title={`Blog — Xavi Ibáñez`}>
  <div class="blog-page">
    <div class="blog-header">
      <h1 class="blog-title">{t.blog.allPosts}</h1>
      <p class="blog-subtitle text-muted">
        Thoughts on distributed systems, clean architecture and software engineering.
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-muted">{t.blog.noPosts}</p>
    ) : (
      <div class="posts-grid">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
            lang={lang}
            readMore={t.blog.readMore}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .blog-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .blog-header {
    margin-bottom: 2.5rem;
  }

  .blog-title {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    color: var(--fg);
  }

  .blog-subtitle {
    font-size: 1rem;
    line-height: 1.6;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
