---
import Nav from '@/components/Nav.astro';
import type { Lang } from '@/i18n/utils';
import '@/styles/global.css';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const {
  lang,
  title = 'Xavi Ibáñez — Senior Backend Engineer',
  description = 'Portfolio of Xavi Ibáñez Martínez, Senior Backend Engineer at BBVA Technology. Microservices, cloud-native systems, Java, TypeScript.',
} = Astro.props;
---

<!doctype html>
<html lang={lang} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('xavi-theme');
        const theme = saved || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <Nav lang={lang} />
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="footer-inner">
        <p class="text-muted" style="font-size: 0.85rem;">
          © {new Date().getFullYear()} Xavi Ibáñez Martínez · Built with
          <a href="https://astro.build" style="color: var(--accent); text-decoration: none;">Astro</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  main {
    min-height: calc(100vh - 3.5rem - 60px);
  }

  .footer {
    border-top: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
</style>
